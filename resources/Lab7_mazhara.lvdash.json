{
  "datasets": [
    {
      "name": "12463418",
      "displayName": "Aggregated Revenue Orders and City Coverage Summary",
      "queryLines": [
        "SELECT \r\n",
        "  sum(total_revenue) as revenue,\r\n",
        "  sum(total_orders) as orders,\r\n",
        "  count(distinct city) as cities_covered\r\n",
        "FROM ${catalog}.${schema}.<table_name>"
      ],
      "catalog": "dbr_dev",
      "schema": "mazhara_gold"
    },
    {
      "name": "e2fcc638",
      "displayName": "City Revenue Rankings Dataset",
      "queryLines": [
        "SELECT city, total_revenue \r\n",
        "FROM ${var.catalog}.${var.schema}.<table_name>\r\n",
        "ORDER BY total_revenue DESC"
      ],
      "catalog": "dbr_dev",
      "schema": "mazhara_bronze"
    },
    {
      "name": "2f448ece",
      "displayName": "Citywise Sales Summary by Category and Revenue Metrics",
      "queryLines": [
        "SELECT \r\n",
        "    city, \r\n",
        "    category, \r\n",
        "    sum(total_revenue) as revenue, \r\n",
        "    sum(total_orders) as orders_count,\r\n",
        "    (sum(total_revenue) / sum(total_orders)) as avg_check\r\n",
        "FROM ${var.catalog}.${var.schema}.<table_name>\r\n",
        "GROUP BY city, category"
      ],
      "catalog": "dbr_dev",
      "schema": "mazhara_gold"
    }
  ],
